{
    "release_branch": "master",
    "major_changes": {
        "changes": [
            {
                "pattern": "^(.|\n)*BREAKING_CHANGE(.|\n)*$",
                "kind": "BREAKING CHANGES"
            }
        ]
    },
    "minor_changes": {
        "changes": [
            {
                "pattern": "^feat(.|\n)*$",
                "kind": "Features"
            }
        ]
    },
    "patch_changes": {
        "changes": [
            {
                "pattern": "^fix(.|\n)*$",
                "kind": "Patches"
            }
        ]
    },
    "other_changes": {
        "changes": [
            {
                "pattern": "^chore(.|\n)*$",
                "kind": "Maintenance Items"
            },
            {
                "pattern": "^docs(.|\n)*$",
                "kind": "Documentation"
            }
        ]
    },
    "generate_changelog": true,
    "log_level": "DEBUG",
    "changelog_location": "CHANGELOG.md",
    "git_auth_method": "GITHUB",
    "commit_changes": true,
    "push_changes": true,
    "plugins": {}
}